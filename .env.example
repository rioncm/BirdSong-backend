# Recording object storage (S3/MinIO)
BIRDSONG_S3_ENABLED=true
BIRDSONG_S3_ENDPOINT_URL=http://127.0.0.1:9000
BIRDSONG_S3_ACCESS_KEY=minioadmin
BIRDSONG_S3_SECRET_KEY=minioadmin
BIRDSONG_S3_BUCKET=birdsong-recordings
BIRDSONG_S3_REGION=us-east-1
BIRDSONG_S3_SECURE=false
BIRDSONG_S3_PREFIX=birdsong

# Playback/transcode behavior
BIRDSONG_PLAYBACK_FORMAT=mp3
BIRDSONG_KEEP_WAV_COPY=true
BIRDSONG_DELETE_LOCAL_AFTER_UPLOAD=true

# Optional aliases also supported by the code:
# MINIO_ENDPOINT_URL, MINIO_ACCESS_KEY, MINIO_SECRET_KEY, MINIO_BUCKET,
# AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION, AWS_ENDPOINT_URL
